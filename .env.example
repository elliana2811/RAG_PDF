# Database & Communication
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=fiinlm
REDIS_URL=redis://localhost:6379/0
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_BUCKET_RAW=raw
MINIO_BUCKET_PROCESSED=processed

# Vector Search (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=documents

# Embeddings
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL_NAME=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
GEMINI_API_KEY=
FAST_EMBED_SPARSE_MODEL=prithivida/Splade_PP_en_v1

# OCR & Vision
OCR_ENABLED=true
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai
MISTRAL_MODEL_NAME=mistral-ocr-latest
ENABLE_VISION_FALLBACK=false
OPENAI_API_KEY=
VISION_MODEL_NAME=gpt-4o

# LLM & Processing (MarkItDown / Adapters)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL_NAME=gpt-4o
ETL_CHUNK_SIZE=1000
ETL_CHUNK_OVERLAP=100

# Worker Settings
WORKER_MAX_RETRIES=3
WORKER_RETRY_BASE_DELAY=5

# Security
API_KEY=your_master_api_key_here
